# Select parser provider: claude-cli | opencode-cli | openai-compatible
CV_PARSER_PROVIDER=claude-cli

# Claude CLI binary
# Optional if `claude` is already on PATH
CLAUDE_BIN=claude
CLAUDE_MODEL=sonnet

# OpenCode CLI
OPENCODE_BIN=opencode
OPENCODE_MODEL=

# OpenAI-compatible APIs
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=
