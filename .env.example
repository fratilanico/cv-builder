# Claude CLI on your VM
# Optional if `claude` is already on PATH
CLAUDE_BIN=/Users/nico/.local/bin/claude

# Optional: route parsing through your remote Claude VM over SSH
# Example: CLAUDE_COMMAND=ssh ubuntu@4.231.218.96 claude
CLAUDE_COMMAND=

# Better SSH mode: pass the remote Claude invocation as one command
CLAUDE_SSH_TARGET=
CLAUDE_REMOTE_BIN=claude

# Optional; defaults to `sonnet`
CLAUDE_MODEL=sonnet
